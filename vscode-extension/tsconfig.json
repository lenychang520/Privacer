{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2022",
        "outDir": ".",
        "rootDir": "src",
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", ".vscode-test"]
}
